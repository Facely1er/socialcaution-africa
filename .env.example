# Local-first defaults — no backend required
# Copy to .env for local development (optional; unset VITE_API_URL is enough)

VITE_DEMO_MODE=true
VITE_SITE_URL=https://africa.socialcaution.com

# Optional: enable Express/Mongo backend (requires running backend/)
# VITE_API_URL=http://localhost:5000/api

# Optional: Supabase sync for 30-day challenge (works offline without these)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# A/B parent journey variant (optional)
# VITE_AB_VARIANT=B
